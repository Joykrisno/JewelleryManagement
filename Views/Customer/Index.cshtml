@model IEnumerable<JewelleryManagement.Models.Customer>

@{
    ViewData["Title"] = "গ্রাহক তালিকা";
}

<style>
    .customer-header {
        background: linear-gradient(145deg, #ffffff, #fff9f0);
        padding: 20px;
        border-radius: 25px;
        box-shadow: var(--shadow);
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .customer-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #4a3b1a;
        margin: 0;
    }

        .customer-title i {
            color: #b8860b;
            margin-right: 10px;
        }

    .add-customer-btn {
        background: linear-gradient(145deg, #b8860b, #daa520);
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 30px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .add-customer-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(184, 134, 11, 0.3);
            color: white;
        }

    .search-box {
        background: white;
        border-radius: 50px;
        padding: 8px 20px;
        display: flex;
        align-items: center;
        box-shadow: var(--shadow);
        flex: 1;
        max-width: 400px;
    }

        .search-box input {
            border: none;
            outline: none;
            width: 100%;
            padding: 10px;
            font-size: 1rem;
        }

        .search-box i {
            color: #b8860b;
            font-size: 1.2rem;
        }

    .customer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .customer-card {
        background: white;
        border-radius: 25px;
        padding: 20px;
        box-shadow: var(--shadow);
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 215, 0, 0.1);
        position: relative;
        overflow: hidden;
    }

        .customer-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #b8860b, #daa520, #ffd700);
        }

        .customer-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(184, 134, 11, 0.2);
        }

    .customer-card-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 15px;
    }

    .customer-avatar {
        width: 70px;
        height: 70px;
        background: linear-gradient(145deg, #f5e7c8, #fff4e0);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .customer-info h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: #4a3b1a;
        margin: 0 0 5px 0;
    }

    .customer-phone {
        color: #b8860b;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 5px;
    }

    .customer-status {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .status-active {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .status-premium {
        background: #fff3e0;
        color: #b8860b;
    }

    .status-new {
        background: #e3f2fd;
        color: #1565c0;
    }

    .customer-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin: 20px 0;
        padding: 15px 0;
        border-top: 1px solid #f0e8d8;
        border-bottom: 1px solid #f0e8d8;
    }

    .stat-item {
        text-align: center;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #8a7a5a;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 1.2rem;
        font-weight: 700;
        color: #4a3b1a;
    }

        .stat-value small {
            font-size: 0.8rem;
            color: #b8860b;
        }

    .customer-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .action-btn {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5e7c8;
        color: #b8860b;
        border: none;
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
    }

        .action-btn:hover {
            background: #b8860b;
            color: white;
            transform: scale(1.1);
        }

        .action-btn.delete:hover {
            background: #dc3545;
            color: white;
        }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
    }

    .page-item {
        width: 45px;
        height: 45px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        color: #4a3b1a;
        font-weight: 600;
        box-shadow: var(--shadow);
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .page-item.active {
            background: #b8860b;
            color: white;
        }

        .page-item:hover {
            background: #b8860b;
            color: white;
            transform: translateY(-2px);
        }

    .summary-card {
        background: white;
        border-radius: 25px;
        padding: 20px;
        box-shadow: var(--shadow);
        margin-bottom: 25px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }

    .summary-item {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .summary-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(145deg, #b8860b, #daa520);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .summary-info h4 {
        font-size: 0.9rem;
        color: #8a7a5a;
        margin: 0 0 5px 0;
    }

    .summary-info .number {
        font-size: 1.5rem;
        font-weight: 700;
        color: #4a3b1a;
    }

    @@media (max-width: 768px) {
        .customer-grid {
            grid-template-columns: 1fr;
        }

        .customer-header {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            max-width: 100%;
        }
    }
</style>

