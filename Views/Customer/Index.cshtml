<!-- Customer Header -->
<div class="customer-header">
    <h2 class="customer-title">
        <i class="fas fa-user-friends"></i>
        গ্রাহক তালিকা
    </h2>

    <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" id="searchCustomer" placeholder="গ্রাহকের নাম বা ফোন নম্বর সার্চ করুন..." />
    </div>

    <a href="@Url.Action("Create")" class="add-customer-btn">
        <i class="fas fa-plus-circle"></i>
        নতুন গ্রাহক
    </a>
</div>

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 15px; background: #d4edda; color: #155724; border: none; box-shadow: var(--shadow);">
        <i class="fas fa-check-circle me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Customer Grid -->
<div class="customer-grid" id="customerGrid">
    @foreach (var customer in Model)
    {
        <div class="customer-card">
            <div class="customer-card-header">
                <div class="customer-avatar">
                    @customer.ProfileImage
                </div>
                <div class="customer-info">
                    <h3>@customer.Name</h3>
                    <div class="customer-phone">
                        <i class="fas fa-phone-alt"></i>
                        @customer.Phone
                    </div>
                    <span class="customer-status
                            @(customer.Status == "সক্রিয়" ? "status-active" :
                                                    customer.Status == "প্রিমিয়াম" ? "status-premium" : "status-new")">
                    @customer.Status
                </span>
            </div>
        </div>

            <div class="customer-stats">
                <div class="stat-item">
                    <div class="stat-label">মোট ক্রয়</div>
                    <div class="stat-value">@customer.TotalPurchase <small>গ্রাম</small></div>
                </div>
                <div class="stat-item">
                    <div class="stat-label">সর্বশেষ</div>
                    <div class="stat-value">@customer.LastPurchaseDate</div>
                </div>
            </div>

            <div class="customer-actions">
                <a href="@Url.Action("Details", new { id = customer.Id })" class="action-btn" title="বিস্তারিত">
                    <i class="fas fa-eye"></i>
                </a>
                <a href="@Url.Action("Edit", new { id = customer.Id })" class="action-btn" title="এডিট">
                    <i class="fas fa-edit"></i>
                </a>
                <a href="#" class="action-btn delete" title="ডিলিট" onclick="deleteCustomer(@customer.Id)">
                    <i class="fas fa-trash"></i>
                </a>
                <a href="#" class="action-btn" title="SMS পাঠান">
                    <i class="fas fa-sms"></i>
                </a>
            </div>
        </div>
        }
</div>

<!-- Pagination -->
<div class="pagination">
    <a href="#" class="page-item">
        <i class="fas fa-chevron-left"></i>
    </a>
    <a href="#" class="page-item active">১</a>
    <a href="#" class="page-item">২</a>
    <a href="#" class="page-item">৩</a>
    <a href="#" class="page-item">৪</a>
    <a href="#" class="page-item">৫</a>
    <a href="#" class="page-item">
        <i class="fas fa-chevron-right"></i>
    </a>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchCustomer').addEventListener('keyup', function() {
            let searchTerm = this.value.toLowerCase();
            let cards = document.querySelectorAll('.customer-card');

            cards.forEach(card => {
                let name = card.querySelector('h3').textContent.toLowerCase();
                let phone = card.querySelector('.customer-phone').textContent.toLowerCase();

                if (name.includes(searchTerm) || phone.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });

        // Delete confirmation
        function deleteCustomer(id) {
            if (confirm('আপনি কি নিশ্চিতভাবে গ্রাহকটি ডিলিট করতে চান?')) {
                // এখানে AJAX কল করে ডিলিট করবেন
                alert('গ্রাহক ডিলিট করা হয়েছে!');
            }
        }

        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'))
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
    </script>
}