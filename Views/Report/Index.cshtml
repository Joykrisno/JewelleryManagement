    let currentTab = 'customer';

    $(document).ready(function() {
        loadCustomerDropdown();
        loadBrandStock();
        loadProductStock();
        loadKaratStock();
        loadGoldPurchaseHistory();
    });

    function switchTab(tab) {
        currentTab = tab;
        $('.tab-btn').removeClass('active');

        if (tab === 'customer') {
            $('.tab-btn:eq(0)').addClass('active');
            $('#customerSection').show();
            $('#stockSection').hide();
            $('#goldSection').hide();
        } else if (tab === 'stock') {
            $('.tab-btn:eq(1)').addClass('active');
            $('#customerSection').hide();
            $('#stockSection').show();
            $('#goldSection').hide();
        } else if (tab === 'gold') {
            $('.tab-btn:eq(2)').addClass('active');
            $('#customerSection').hide();
            $('#stockSection').hide();
            $('#goldSection').show();
        }
    }

    function loadCustomerDropdown() {
        let options = '<option value="">-- গ্রাহক নির্বাচন করুন --</option>';
        customers.forEach(c => {
            options += `<option value="${c.id}">${c.name} (${c.phone})</option>`;
        });
        $('#customerSelect').html(options);
    }

    function loadCustomerReport() {
        const customerId = parseInt($('#customerSelect').val());
        if (!customerId) {
            $('#customerTableBody').html('<tr><td colspan="6" class="empty-state"><i class="fas fa-user"></i><p>গ্রাহক নির্বাচন করুন</p></td></tr>');
            $('#custTotalPurchase').text('৳ 0');
            $('#custTotalSell').text('৳ 0');
            $('#custNetAmount').text('৳ 0');
            $('#custTotalGold').text('0 গ্রাম');
            return;
        }

        const customer = customers.find(c => c.id === customerId);
        const transactions = customerTransactions.filter(t => t.customerId === customerId);

        let totalPurchase = 0;
        let totalSell = 0;
        let purchaseCount = 0;
        let sellCount = 0;
        let totalGold = 0;
        let totalVori = 0;

        transactions.forEach(t => {
            if (t.type === 'purchase') {
                totalPurchase += t.amount;
                purchaseCount++;
            } else {
                totalSell += t.amount;
                sellCount++;
            }
            totalGold += t.weight;
            totalVori += t.vori;
        });

        const netAmount = totalSell - totalPurchase;
        const netColor = netAmount >= 0 ? '#2e7d32' : '#c62828';

        $('#custTotalPurchase').text('৳ ' + totalPurchase.toLocaleString());
        $('#custPurchaseCount').text(purchaseCount + ' টি');
        $('#custTotalSell').text('৳ ' + totalSell.toLocaleString());
        $('#custSellCount').text(sellCount + ' টি');
        $('#custNetAmount').html((netAmount >= 0 ? '৳ ' : '৳ -') + Math.abs(netAmount).toLocaleString());
        $('#custNetAmount').css('color', netColor);
        $('#custTransactionCount').text((purchaseCount + sellCount) + ' বার লেনদেন');
        $('#custTotalGold').text(totalGold.toFixed(2) + ' গ্রাম');
        $('#custTotalVori').text(totalVori.toFixed(2) + ' ভরি');

        // Render transaction table
        let html = '';
        const sorted = [...transactions].sort((a, b) => b.date.localeCompare(a.date));

        sorted.forEach(t => {
            const typeText = t.type === 'purchase' ? 'ক্রয়' : 'বিক্রয়';
            const typeClass = t.type === 'purchase' ? 'color: #1565c0;' : 'color: #2e7d32;';
            const typeIcon = t.type === 'purchase' ? '<i class="fas fa-arrow-down"></i>' : '<i class="fas fa-arrow-up"></i>';

            html += `<tr>
                        <td>${formatDate(t.date)}</td>
                        <td style="${typeClass} font-weight: 600;">${typeIcon} ${typeText}</td>
                        <td>${t.item}</td>
                        <td>${t.karat}</td>
                        <td>${t.weight.toFixed(2)} গ্রাম<br><small>(${t.vori.toFixed(3)} ভরি)</small></td>
                        <td style="font-weight: 700;">৳ ${t.amount.toLocaleString()}</td>
                    </tr>`;
        });

        if (sorted.length === 0) {
            html = '<tr><td colspan="6" class="empty-state"><i class="fas fa-history"></i><p>কোনো লেনদেন নেই</p></td></tr>';
        }

        $('#customerTableBody').html(html);
    }

    function loadBrandStock() {
        let html = '';
        let totalProducts = 0;

        brandStock.forEach(b => {
            totalProducts += b.itemCount;
            html += `<div class="brand-item">
                        <div class="brand-name">
                            <div class="brand-icon"><i class="fas ${b.icon}"></i></div>
                            <div>
                                <strong>${b.brand}</strong>
                                <div style="font-size: 11px; color: #999;">${b.itemCount} টি পণ্য</div>
                            </div>
                        </div>
                        <div class="brand-stats">
                            <div class="brand-weight">${b.totalWeight.toFixed(2)} গ্রাম</div>
                            <div class="brand-count">(${b.totalVori.toFixed(2)} ভরি) | ৳ ${b.value.toLocaleString()}</div>
                        </div>
                    </div>`;
        });

        $('#brandStockList').html(html);
        $('#totalBrandProducts').text(totalProducts);
    }

    function loadProductStock() {
        let html = '';
        let totalItems = 0;

        productStock.forEach(p => {
            totalItems += p.quantity;
            html += `<tr>
                        <td><strong>${p.name}</strong></td>
                        <td>${p.brand}</td>
                        <td>${p.karat}</td>
                        <td>${p.quantity} টি</td>
                        <td>${p.weight.toFixed(2)} গ্রাম (${p.vori.toFixed(2)} ভরি)</td>
                     </tr>`;
        });

        $('#productStockBody').html(html);
        $('#totalProductItems').text(totalItems);
    }

    function loadKaratStock() {
        let html = '';
        let totalGold = 0;

        karatStock.forEach(k => {
            totalGold += k.weight;
            html += `<div class="karat-item">
                        <div class="karat-name">${k.karat}</div>
                        <div class="karat-weight">${k.weight.toFixed(2)} <small>গ্রাম</small></div>
                        <div class="karat-weight" style="font-size: 12px;">(${k.vori.toFixed(2)} ভরি)</div>
                        <div style="font-size: 11px; color: #999;">৳ ${k.value.toLocaleString()}</div>
                    </div>`;
        });

        $('#karatStockGrid').html(html);
        $('#totalGoldWeight').text(totalGold.toFixed(2));
    }

    function loadGoldPurchaseHistory() {
        let html = '';

        goldPurchases.forEach(p => {
            html += `<tr>
                        <td>${formatDate(p.date)}</td>
                        <td>${p.supplier}</td>
                        <td>${p.karat}</td>
                        <td>${p.weight.toFixed(2)} গ্রাম (${p.vori.toFixed(2)} ভরি)</td>
                        <td>৳ ${p.amount.toLocaleString()}</td>
                     </tr>`;
        });

        $('#goldPurchaseBody').html(html);
    }

    function formatDate(dateStr) {
        const date = new Date(dateStr);
        const days = ['রবি', 'সোম', 'মঙ্গল', 'বুধ', 'বৃহ', 'শুক্র', 'শনি'];
        const months = ['জানু', 'ফেব্রু', 'মার্চ', 'এপ্রিল', 'মে', 'জুন', 'জুলাই', 'আগস্ট', 'সেপ্টে', 'অক্টো', 'নভে', 'ডিসে'];
        return `${days[date.getDay()]} ${date.getDate()} ${months[date.getMonth()]}`;
    }

    function showToast(type, message) {
        const toast = document.createElement('div');
        toast.className = 'toast-notification ' + type;
        toast.innerHTML = '<i class="fas ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle') + '"></i> ' + message;
        document.body.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => { if(toast.parentNode) toast.parentNode.removeChild(toast); }, 300);
        }, 2000);
    }
</script>