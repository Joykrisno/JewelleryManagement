@{
    ViewData["Title"] = "ক্রয়";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #f8f9fa;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        padding-bottom: 30px;
    }

    .mobile-container {
        max-width: 500px;
        margin: 0 auto;
        padding: 16px;
        background: #f8f9fa;
        min-height: 100vh;
    }

    .app-header {
        background: white;
        border-radius: 24px;
        padding: 16px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .header-title h1 {
        font-size: 20px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .header-title p {
        font-size: 12px;
        color: #b8860b;
        margin: 4px 0 0 0;
    }

    .header-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
    }

    /* Gold Rate Input */
    .gold-rate-card {
        background: linear-gradient(135deg, #fff9f0, #fff5e8);
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        border: 1px solid #ffe0b3;
    }

    .gold-rate-title {
        font-size: 16px;
        font-weight: 700;
        color: #b8860b;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .gold-rate-input-box {
        display: flex;
        align-items: center;
        gap: 12px;
        background: white;
        border-radius: 20px;
        padding: 8px 16px;
        border: 1px solid #e0e0e0;
    }

        .gold-rate-input-box span {
            color: #b8860b;
            font-weight: 700;
            font-size: 20px;
        }

        .gold-rate-input-box input {
            flex: 1;
            padding: 12px;
            border: none;
            font-size: 22px;
            font-weight: 700;
            text-align: right;
            background: transparent;
            color: #1a1a2e;
        }

            .gold-rate-input-box input:focus {
                outline: none;
            }

    .form-card {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title i {
            color: #b8860b;
        }

    .custom-select {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        font-size: 15px;
        background: white;
        margin-bottom: 16px;
        font-family: inherit;
        cursor: pointer;
    }

    .input-group {
        margin-bottom: 16px;
    }

    .input-label {
        font-size: 13px;
        color: #666;
        margin-bottom: 8px;
        display: block;
        font-weight: 500;
    }

    .input-field {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        font-size: 15px;
    }

    .weight-calculator {
        background: linear-gradient(135deg, #fff9f0, #fff5e8);
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid #ffe0b3;
    }

    .calc-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 20px;
        text-align: center;
        color: #b8860b;
    }

    .weight-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 20px;
    }

    .weight-item {
        text-align: center;
        background: white;
        border-radius: 20px;
        padding: 12px 8px;
        border: 1px solid #f0e0c0;
    }

    .weight-label {
        font-size: 14px;
        font-weight: 700;
        color: #b8860b;
        display: block;
        margin-bottom: 8px;
    }

        .weight-label small {
            font-size: 10px;
            font-weight: 400;
            color: #999;
            display: block;
        }

    .weight-input {
        width: 100%;
        text-align: center;
        border: none;
        padding: 10px 0;
        font-size: 18px;
        font-weight: 700;
        background: transparent;
        color: #1a1a2e;
    }

        .weight-input:focus {
            outline: none;
            color: #b8860b;
        }

    .gram-display {
        margin-top: 16px;
        padding: 14px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border-radius: 20px;
        text-align: center;
        color: white;
        font-weight: 600;
        font-size: 14px;
    }

    .rate-cards {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .rate-card {
        flex: 1;
        background: linear-gradient(135deg, #fff8f0, #fff4e6);
        border-radius: 16px;
        padding: 12px 8px;
        text-align: center;
        border: 1px solid #ffe0b3;
        min-width: 70px;
    }

    .rate-card-title {
        font-size: 11px;
        color: #b8860b;
        font-weight: 500;
        margin-bottom: 6px;
    }

    .rate-card-value {
        font-size: 14px;
        font-weight: 700;
        color: #b8860b;
    }

    .add-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border: none;
        border-radius: 30px;
        font-size: 16px;
        font-weight: 600;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
    }

        .add-btn:active {
            transform: scale(0.98);
        }

    .items-list {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .item-card {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 14px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .item-info {
        flex: 1;
    }

    .item-name {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 6px;
        font-size: 14px;
    }

    .item-details {
        font-size: 11px;
        color: #666;
    }

    .item-price {
        text-align: right;
    }

    .item-amount {
        font-weight: 700;
        color: #b8860b;
        font-size: 16px;
    }

    .item-weight {
        font-size: 10px;
        color: #999;
        margin-top: 4px;
    }

    .delete-item {
        width: 36px;
        height: 36px;
        background: #fee;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #dc3545;
        cursor: pointer;
        margin-left: 12px;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #999;
    }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.5;
        }

    .footer-summary {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        position: sticky;
        bottom: 0;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .summary-label {
        color: #666;
        font-size: 14px;
    }

    .summary-value {
        font-weight: 700;
        color: #1a1a2e;
        font-size: 14px;
    }

    .grand-total {
        border-top: 2px solid #f0f0f0;
        padding-top: 12px;
        margin-top: 8px;
    }

        .grand-total .summary-label {
            font-size: 16px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .grand-total .summary-value {
            font-size: 20px;
            color: #b8860b;
        }

    .action-buttons {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }

    .btn-clear {
        flex: 1;
        padding: 14px;
        background: #f0f0f0;
        border: none;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        color: #666;
        cursor: pointer;
    }

    .btn-save {
        flex: 2;
        padding: 14px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border: none;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        color: white;
        cursor: pointer;
    }

    .modal-custom {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .modal-content-custom {
        background: white;
        border-radius: 32px;
        max-width: 320px;
        width: 100%;
        text-align: center;
        padding: 24px;
    }

    .modal-icon {
        width: 64px;
        height: 64px;
        background: #d4edda;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        color: #28a745;
        font-size: 32px;
    }

    .modal-title-custom {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .modal-text {
        color: #666;
        margin-bottom: 20px;
    }

    .modal-details {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 12px;
        margin: 16px 0;
        text-align: left;
    }

    .modal-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border: none;
        border-radius: 30px;
        color: white;
        font-weight: 600;
        cursor: pointer;
    }

    .toast-notification {
        position: fixed;
        bottom: 20px;
        left: 20px;
        right: 20px;
        background: #1a1a2e;
        color: white;
        padding: 14px 20px;
        border-radius: 30px;
        text-align: center;
        font-size: 14px;
        z-index: 1100;
    }

        .toast-notification.success {
            background: #28a745;
        }

        .toast-notification.error {
            background: #dc3545;
        }
</style>

<div class="mobile-container">
    <!-- Header -->
    <div class="app-header">
        <div class="header-title">
            <h1>ক্রয়</h1>
            <p>সোনা ক্রয় করুন</p>
        </div>
        <div class="header-icon">
            <i class="fas fa-shopping-cart"></i>
        </div>
    </div>

    <!-- Gold Rate Input -->
    <div class="gold-rate-card">
        <div class="gold-rate-title">
            <i class="fas fa-chart-line"></i>
            সোনার দর (প্রতি ভরি)
        </div>
        <div class="gold-rate-input-box">
            <span>৳</span>
            <input type="number" id="rateInput" value="5850" oninput="updateRate()">
            <span>/ভরি</span>
        </div>
    </div>

    <!-- Customer Selection -->
    <div class="form-card">
        <div class="section-title">
            <i class="fas fa-user"></i>
            গ্রাহক নির্বাচন
        </div>
        <select class="custom-select" id="customerSelect">
            <option value="">-- গ্রাহক নির্বাচন করুন --</option>
        </select>
    </div>

    <!-- Item Form -->
    <div class="form-card">
        <div class="section-title">
            <i class="fas fa-gem"></i>
            আইটেম তথ্য
        </div>

        <div class="input-group">
            <label class="input-label">আইটেমের নাম</label>
            <div style="display: flex; gap: 8px;">
                <select class="custom-select" id="itemSelect" style="flex: 2; margin-bottom: 0;" onchange="selectItem()">
                    <option value="">-- নির্বাচন করুন --</option>
                    <option value="IC">IC</option>
                    <option value="Dubai">Dubai</option>
                    <option value="Bangla">Bangla</option>
                    <option value="সোনার চেইন">সোনার চেইন</option>
                </select>
                <input type="text" class="input-field" id="itemName" placeholder="নিজে লিখুন" style="flex: 1; margin-bottom: 0;">
            </div>
        </div>

        <!-- Weight Calculator - Independent Units (No auto-conversion) -->
        <div class="weight-calculator">
            <div class="calc-title">
                <i class="fas fa-weight-hanging"></i> ওজন নির্ধারণ করুন
            </div>
            <div class="weight-grid">
                <div class="weight-item">
                    <label class="weight-label">ভরি <small>Vori</small></label>
                    <input type="number" step="any" class="weight-input" id="vori" value="0" oninput="updateDisplay()">
                </div>
                <div class="weight-item">
                    <label class="weight-label">আনা <small>Ana</small></label>
                    <input type="number" step="any" class="weight-input" id="ana" value="0" oninput="updateDisplay()">
                </div>
                <div class="weight-item">
                    <label class="weight-label">রতি <small>Roti</small></label>
                    <input type="number" step="any" class="weight-input" id="rati" value="0" oninput="updateDisplay()">
                </div>
                <div class="weight-item">
                    <label class="weight-label">পয়েন্ট <small>Point</small></label>
                    <input type="number" step="any" class="weight-input" id="point" value="0" oninput="updateDisplay()">
                </div>
            </div>
            <div class="gram-display" id="gramDisplay">
                <i class="fas fa-chart-line"></i> = 0.000 গ্রাম (0.0000 ভরি)
            </div>
        </div>

        <!-- Rate Cards -->
        <div class="rate-cards">
            <div class="rate-card"><div class="rate-card-title">প্রতি ভরি</div><div class="rate-card-value" id="perVori">৳ 5,850</div></div>
            <div class="rate-card"><div class="rate-card-title">প্রতি আনা</div><div class="rate-card-value" id="perAna">৳ 365.63</div></div>
            <div class="rate-card"><div class="rate-card-title">প্রতি রতি</div><div class="rate-card-value" id="perRati">৳ 60.94</div></div>
            <div class="rate-card"><div class="rate-card-title">প্রতি পয়েন্ট</div><div class="rate-card-value" id="perPoint">৳ 10.16</div></div>
        </div>

        <!-- Total Price -->
        <div class="input-group">
            <label class="input-label">এই আইটেমের মূল্য</label>
            <div style="background: linear-gradient(135deg, #fff4e0, #fff9f0); border-radius: 16px; padding: 14px 16px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="color: #b8860b; font-weight: 700;">৳</span>
                    <input type="text" id="totalPrice" value="0" style="font-size: 22px; font-weight: 800; color: #b8860b; border: none; outline: none; background: transparent; width: 100%;" oninput="syncFromPrice()">
                </div>
                <div id="priceWords" style="font-size: 13px; color: #666; margin-top: 8px;">শূন্য টাকা মাত্র</div>
            </div>
        </div>

        <button class="add-btn" onclick="addItem()">
            <i class="fas fa-plus-circle"></i> আইটেম যোগ করুন
        </button>
    </div>

    <!-- Items List -->
    <div class="items-list">
        <div class="section-title"><i class="fas fa-list"></i> যোগকৃত আইটেম</div>
        <div id="itemsContainer">
            <div class="empty-state"><i class="fas fa-box-open"></i><p>কোনো আইটেম যোগ করা হয়নি</p></div>
        </div>
    </div>

    <!-- Footer Summary -->
    <div class="footer-summary">
        <div class="summary-row"><span class="summary-label">মোট আইটেম</span><span class="summary-value" id="totalItems">0</span></div>
        <div class="summary-row"><span class="summary-label">মোট ওজন</span><span class="summary-value" id="totalWeight">0.000 গ্রাম</span></div>
        <div class="summary-row grand-total"><span class="summary-label">মোট মূল্য</span><span class="summary-value" id="grandTotal">৳ 0</span></div>
        <div class="action-buttons">
            <button class="btn-clear" onclick="clearAll()"><i class="fas fa-trash-alt"></i> ক্লিয়ার</button>
            <button class="btn-save" onclick="savePurchase()"><i class="fas fa-save"></i> ক্রয় সম্পন্ন</button>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal-custom" id="successModal">
    <div class="modal-content-custom">
        <div class="modal-icon"><i class="fas fa-check-circle"></i></div>
        <div class="modal-title-custom">ক্রয় সম্পন্ন!</div>
        <div class="modal-text">ক্রয় সফলভাবে সম্পন্ন হয়েছে</div>
        <div class="modal-details" id="modalDetails"></div>
        <button class="modal-btn" onclick="closeModal()">ঠিক আছে</button>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/js/all.min.js"></script>
<script>
    // Conversion constants
    const VORI_TO_GRAM = 11.664;
    const VORI_TO_ANA = 16;
    const ANA_TO_RATI = 6;
    const RATI_TO_POINT = 6;

    // Variables
    let currentRate = 5850;
    let items = [];

    // Customers
    const customers = [
        { id: 1, name: "রহিম মিয়া", phone: "01712-345678" },
        { id: 2, name: "করিমা বেগম", phone: "01812-345679" },
        { id: 3, name: "শফিকুল ইসলাম", phone: "01912-345680" },
        { id: 4, name: "নাসরিন আক্তার", phone: "01612-345681" },
        { id: 5, name: "জাহিদ হাসান", phone: "01512-345682" },
        { id: 6, name: "ফাতেমা বেগম", phone: "01312-345683" },
        { id: 7, name: "আব্দুল্লাহ আল মামুন", phone: "01711-123456" },
        { id: 8, name: "শাহীন আক্তার", phone: "01822-234567" }
    ];

    // Bengali number to words
    const ones = ["", "এক", "দুই", "তিন", "চার", "পাঁচ", "ছয়", "সাত", "আট", "নয়"];
    const teens = ["দশ", "এগারো", "বারো", "তেরো", "চৌদ্দ", "পনেরো", "ষোলো", "সতেরো", "আঠারো", "উনিশ"];
    const tens = ["", "দশ", "বিশ", "ত্রিশ", "চল্লিশ", "পঞ্চাশ", "ষাট", "সত্তর", "আশি", "নব্বই"];

    function toBengaliWords(num) {
        if (num === 0) return "";
        if (num < 10) return ones[num];
        if (num < 20) return teens[num - 10];
        let t = Math.floor(num / 10);
        let o = num % 10;
        return tens[t] + (o > 0 ? " " + ones[o] : "");
    }

    function formatTaka(amount) {
        if (amount === 0 || isNaN(amount)) return "শূন্য টাকা মাত্র";
        let taka = Math.floor(amount);
        let poisha = Math.round((amount - taka) * 100);
        let result = toBengaliWords(taka) + " টাকা";
        if (poisha > 0) result += " ও " + toBengaliWords(poisha) + " পয়সা";
        return result + " মাত্র";
    }

    function formatNumber(num) {
        if (isNaN(num)) return "0";
        return Math.round(num).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }

    // Auto remove zero when focus on input
    function setupAutoClearZero() {
        $('.weight-input, #totalPrice').on('focus', function() {
            if ($(this).val() == '0' || $(this).val() == '0.00' || $(this).val() == '0.000') {
                $(this).val('');
            }
        });

        $('.weight-input, #totalPrice').on('blur', function() {
            if ($(this).val() === '' || $(this).val() === null) {
                $(this).val('0');
                updateDisplay();
            }
        });
    }

    // Calculate total vori from all units (for display only)
    function calculateTotalVori() {
        let vori = parseFloat($('#vori').val()) || 0;
        let ana = parseFloat($('#ana').val()) || 0;
        let rati = parseFloat($('#rati').val()) || 0;
        let point = parseFloat($('#point').val()) || 0;

        let totalVori = vori + (ana / VORI_TO_ANA) + (rati / (VORI_TO_ANA * ANA_TO_RATI)) + (point / (VORI_TO_ANA * ANA_TO_RATI * RATI_TO_POINT));
        return totalVori;
    }

    // Update display only (no auto-conversion between inputs)
    function updateDisplay() {
        let totalVori = calculateTotalVori();
        let gram = totalVori * VORI_TO_GRAM;
        let price = totalVori * currentRate;

        $('#gramDisplay').html(`<i class="fas fa-chart-line"></i> = ${gram.toFixed(3)} গ্রাম (${totalVori.toFixed(4)} ভরি)`);
        $('#totalPrice').val(formatNumber(price));
        $('#priceWords').text(formatTaka(price));
    }

    // Update rate displays
    function updateRate() {
        currentRate = parseFloat($('#rateInput').val()) || 0;
        let perAna = currentRate / VORI_TO_ANA;
        let perRati = perAna / ANA_TO_RATI;
        let perPoint = perRati / RATI_TO_POINT;

        $('#perVori').text('৳ ' + formatNumber(currentRate));
        $('#perAna').text('৳ ' + perAna.toFixed(2));
        $('#perRati').text('৳ ' + perRati.toFixed(2));
        $('#perPoint').text('৳ ' + perPoint.toFixed(2));

        updateDisplay();
    }

    // Sync from price (when user manually enters price)
    function syncFromPrice() {
        let price = parseFloat($('#totalPrice').val().replace(/,/g, '')) || 0;
        if (currentRate > 0 && price > 0) {
            let totalVori = price / currentRate;
            let gram = totalVori * VORI_TO_GRAM;
            $('#gramDisplay').html(`<i class="fas fa-chart-line"></i> = ${gram.toFixed(3)} গ্রাম (${totalVori.toFixed(4)} ভরি)`);
            $('#priceWords').text(formatTaka(price));
        } else if (price === 0) {
            $('#gramDisplay').html(`<i class="fas fa-chart-line"></i> = 0.000 গ্রাম (0.0000 ভরি)`);
            $('#priceWords').text('শূন্য টাকা মাত্র');
        }
    }

    // Load customers
    function loadCustomers() {
        let html = '<option value="">-- গ্রাহক নির্বাচন করুন --</option>';
        for (let c of customers) {
            html += `<option value="${c.id}">${c.name} (${c.phone})</option>`;
        }
        $('#customerSelect').html(html);
    }

    // Select item from dropdown
    function selectItem() {
        let val = $('#itemSelect').val();
        if (val) $('#itemName').val(val);
    }

    $('#itemName').on('input', function() {
        if ($(this).val() !== $('#itemSelect').val()) {
            $('#itemSelect').val('');
        }
    });

    // Add item
    function addItem() {
        let customerId = $('#customerSelect').val();
        let customerName = $('#customerSelect option:selected').text().split('(')[0].trim();
        let itemName = $('#itemName').val().trim();
        let vori = parseFloat($('#vori').val()) || 0;
        let ana = parseFloat($('#ana').val()) || 0;
        let rati = parseFloat($('#rati').val()) || 0;
        let point = parseFloat($('#point').val()) || 0;
        let totalVori = calculateTotalVori();
        let gram = totalVori * VORI_TO_GRAM;
        let price = parseFloat($('#totalPrice').val().replace(/,/g, '')) || 0;

        if (!customerId) { showToast('error', 'গ্রাহক নির্বাচন করুন'); return; }
        if (!itemName) { showToast('error', 'আইটেমের নাম লিখুন'); return; }
        if (totalVori <= 0) { showToast('error', 'সঠিক ওজন দিন'); return; }

        items.push({
            id: Date.now(),
            customerId, customerName, itemName,
            vori: vori, ana: ana, rati: rati, point: point,
            totalVori: totalVori, gram: gram, price: price, rate: currentRate
        });

        renderItems();
        clearForm();
        showToast('success', 'আইটেম যোগ করা হয়েছে');
    }

    // Render items list
    function renderItems() {
        if (items.length === 0) {
            $('#itemsContainer').html('<div class="empty-state"><i class="fas fa-box-open"></i><p>কোনো আইটেম যোগ করা হয়নি</p></div>');
            updateSummary();
            return;
        }

        let html = '';
        for (let item of items) {
            let weightText = '';
            if (item.vori > 0) weightText += item.vori + ' ভরি ';
            if (item.ana > 0) weightText += item.ana + ' আনা ';
            if (item.rati > 0) weightText += item.rati + ' রতি ';
            if (item.point > 0) weightText += item.point + ' পয়েন্ট';
            if (weightText === '') weightText = '0 ভরি';

            html += `<div class="item-card">
                <div class="item-info">
                    <div class="item-name">${escapeHtml(item.itemName)}</div>
                    <div class="item-details">${weightText}</div>
                </div>
                <div class="item-price">
                    <div class="item-amount">৳ ${formatNumber(item.price)}</div>
                    <div class="item-weight">${item.gram.toFixed(2)} গ্রাম</div>
                </div>
                <div class="delete-item" onclick="deleteItem(${item.id})"><i class="fas fa-trash-alt"></i></div>
            </div>`;
        }
        $('#itemsContainer').html(html);
        updateSummary();
    }

    function escapeHtml(text) {
        if (!text) return '';
        return text.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    function deleteItem(id) {
        if (confirm('আইটেমটি ডিলিট করতে চান?')) {
            items = items.filter(i => i.id !== id);
            renderItems();
            showToast('success', 'আইটেম ডিলিট করা হয়েছে');
        }
    }

    function clearForm() {
        $('#itemName').val('');
        $('#itemSelect').val('');
        $('#vori').val('0');
        $('#ana').val('0');
        $('#rati').val('0');
        $('#point').val('0');
        $('#totalPrice').val('0');
        $('#gramDisplay').html('<i class="fas fa-chart-line"></i> = 0.000 গ্রাম (0.0000 ভরি)');
        $('#priceWords').text('শূন্য টাকা মাত্র');
    }

    function clearAll() {
        if (items.length === 0) return;
        if (confirm('সব আইটেম ডিলিট করতে চান?')) {
            items = [];
            renderItems();
            showToast('success', 'সব আইটেম ডিলিট করা হয়েছে');
        }
    }

    function updateSummary() {
        let totalItems = items.length;
        let totalVori = 0, totalGram = 0, grandTotal = 0;
        for (let item of items) {
            totalVori += item.totalVori;
            totalGram += item.gram;
            grandTotal += item.price;
        }
        $('#totalItems').text(totalItems);
        $('#totalWeight').text(totalGram.toFixed(3) + ' গ্রাম (' + totalVori.toFixed(3) + ' ভরি)');
        $('#grandTotal').text('৳ ' + formatNumber(grandTotal));
    }

    function savePurchase() {
        if (items.length === 0) { showToast('error', 'কোনো আইটেম যোগ করা হয়নি'); return; }
        let customerId = $('#customerSelect').val();
        if (!customerId) { showToast('error', 'গ্রাহক নির্বাচন করুন'); return; }

        let totalVori = 0, totalGram = 0, grandTotal = 0;
        for (let item of items) {
            totalVori += item.totalVori;
            totalGram += item.gram;
            grandTotal += item.price;
        }

        let customerName = $('#customerSelect option:selected').text().split('(')[0].trim();
        $('#modalDetails').html(`
            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;"><span>গ্রাহক:</span><span><strong>${escapeHtml(customerName)}</strong></span></div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;"><span>মোট আইটেম:</span><span><strong>${items.length} টি</strong></span></div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;"><span>মোট ওজন:</span><span><strong>${totalGram.toFixed(3)} গ্রাম</strong><br><small>(${totalVori.toFixed(3)} ভরি)</small></span></div>
            <div style="display: flex; justify-content: space-between; margin-top: 8px; padding-top: 8px; border-top: 1px solid #e0e0e0;"><span style="font-weight: 600;">মোট মূল্য:</span><span style="font-weight: 700; color: #b8860b;">৳ ${formatNumber(grandTotal)}</span></div>
        `);
        $('#successModal').fadeIn(200);
    }

    function closeModal() {
        $('#successModal').fadeOut(200);
        items = [];
        renderItems();
        clearForm();
        showToast('success', 'ক্রয় সম্পন্ন হয়েছে');
    }

    function showToast(type, message) {
        let toast = $('<div>').addClass('toast-notification ' + type).html('<i class="fas ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle') + '"></i> ' + message);
        $('body').append(toast);
        setTimeout(() => { toast.fadeOut(300, function() { $(this).remove(); }); }, 2000);
    }

    // Initialize
    $(document).ready(function() {
        loadCustomers();
        updateRate();
        setupAutoClearZero();
    });
</script>