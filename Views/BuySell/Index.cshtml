@{
    ViewData["Title"] = "ক্রয়";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #f8f9fa;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        padding-bottom: 30px;
    }

    .mobile-container {
        max-width: 500px;
        margin: 0 auto;
        padding: 16px;
        background: #f8f9fa;
        min-height: 100vh;
    }

    /* Header */
    .app-header {
        background: white;
        border-radius: 24px;
        padding: 16px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .header-title h1 {
        font-size: 20px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .header-title p {
        font-size: 12px;
        color: #b8860b;
        margin: 4px 0 0 0;
    }

    .header-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
    }

    /* Gold Rate Card */
    .gold-rate-card {
        background: white;
        border-radius: 20px;
        padding: 16px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .rate-title {
        font-size: 14px;
        color: #666;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .rate-title i {
            color: #b8860b;
        }

    .rate-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
        margin-top: 8px;
        max-height: 200px;
        overflow-y: auto;
    }

    .rate-item {
        text-align: center;
        padding: 10px 6px;
        background: #f8f9fa;
        border-radius: 14px;
        transition: all 0.2s;
        cursor: pointer;
        border: 1px solid #eee;
    }

        .rate-item.active {
            background: linear-gradient(135deg, #b8860b, #daa520);
            border-color: transparent;
        }

            .rate-item.active .rate-karat,
            .rate-item.active .rate-value {
                color: white;
            }

    .rate-karat {
        font-size: 12px;
        font-weight: 600;
        color: #1a1a2e;
    }

    .rate-value {
        font-size: 12px;
        font-weight: 700;
        color: #b8860b;
        margin-top: 4px;
    }

    /* Form Card */
    .form-card {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title i {
            color: #b8860b;
        }

    /* Select Dropdown */
    .custom-select {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        font-size: 15px;
        background: white;
        margin-bottom: 16px;
        font-family: inherit;
        transition: all 0.2s;
        cursor: pointer;
    }

        .custom-select:focus {
            outline: none;
            border-color: #b8860b;
            box-shadow: 0 0 0 3px rgba(184, 134, 11, 0.1);
        }

    /* Input Group */
    .input-group {
        margin-bottom: 16px;
    }

    .input-label {
        font-size: 13px;
        color: #666;
        margin-bottom: 8px;
        display: block;
        font-weight: 500;
    }

    .input-field {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        font-size: 15px;
        transition: all 0.2s;
    }

        .input-field:focus {
            outline: none;
            border-color: #b8860b;
            box-shadow: 0 0 0 3px rgba(184, 134, 11, 0.1);
        }

    /* Weight Calculator */
    .weight-calculator {
        background: #f8f9fa;
        border-radius: 20px;
        padding: 16px;
        margin-bottom: 20px;
    }

    .calc-title {
        font-size: 13px;
        color: #666;
        margin-bottom: 12px;
        text-align: center;
        font-weight: 500;
    }

    .calc-buttons {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
    }

    .calc-btn {
        flex: 1;
        padding: 12px;
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 14px;
        font-size: 14px;
        font-weight: 600;
        color: #1a1a2e;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

        .calc-btn.active {
            background: linear-gradient(135deg, #b8860b, #daa520);
            border-color: transparent;
            color: white;
        }

    .calc-input-group {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .calc-input {
        flex: 1;
        padding: 12px;
        border: 1px solid #e0e0e0;
        border-radius: 14px;
        font-size: 14px;
        text-align: center;
    }

    .calc-unit {
        font-size: 14px;
        color: #666;
        min-width: 45px;
        font-weight: 500;
    }

    .total-weight {
        margin-top: 12px;
        padding: 12px;
        background: white;
        border-radius: 14px;
        text-align: center;
        font-size: 14px;
        color: #b8860b;
        font-weight: 600;
    }

    /* Add Button */
    .add-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border: none;
        border-radius: 30px;
        font-size: 16px;
        font-weight: 600;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .add-btn:active {
            transform: scale(0.98);
        }

    /* Items List */
    .items-list {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .item-card {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 14px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .item-info {
        flex: 1;
    }

    .item-name {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 6px;
        font-size: 14px;
    }

    .item-details {
        font-size: 11px;
        color: #666;
    }

    .item-price {
        text-align: right;
    }

    .item-amount {
        font-weight: 700;
        color: #b8860b;
        font-size: 16px;
    }

    .item-weight {
        font-size: 10px;
        color: #999;
        margin-top: 4px;
    }

    .delete-item {
        width: 36px;
        height: 36px;
        background: #fee;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #dc3545;
        cursor: pointer;
        margin-left: 12px;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #999;
    }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.5;
        }

    /* Footer Summary */
    .footer-summary {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        position: sticky;
        bottom: 0;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .summary-label {
        color: #666;
        font-size: 14px;
    }

    .summary-value {
        font-weight: 700;
        color: #1a1a2e;
        font-size: 14px;
    }

    .grand-total {
        border-top: 2px solid #f0f0f0;
        padding-top: 12px;
        margin-top: 8px;
    }

        .grand-total .summary-label {
            font-size: 16px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .grand-total .summary-value {
            font-size: 20px;
            color: #b8860b;
        }

    .action-buttons {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }

    .btn-clear {
        flex: 1;
        padding: 14px;
        background: #f0f0f0;
        border: none;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        color: #666;
        cursor: pointer;
    }

    .btn-save {
        flex: 2;
        padding: 14px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border: none;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        color: white;
        cursor: pointer;
    }

    /* Modal */
    .modal-custom {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .modal-content-custom {
        background: white;
        border-radius: 32px;
        max-width: 320px;
        width: 100%;
        text-align: center;
        padding: 24px;
        animation: modalIn 0.3s ease;
    }

    @@keyframes modalIn {
        from {
            transform: scale(0.9);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .modal-icon {
        width: 64px;
        height: 64px;
        background: #d4edda;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        color: #28a745;
        font-size: 32px;
    }

    .modal-title-custom {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .modal-text {
        color: #666;
        margin-bottom: 20px;
    }

    .modal-details {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 12px;
        margin: 16px 0;
        text-align: left;
    }

    .modal-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #b8860b, #daa520);
        border: none;
        border-radius: 30px;
        color: white;
        font-weight: 600;
        cursor: pointer;
    }

    /* Toast Notification */
    .toast-notification {
        position: fixed;
        bottom: 20px;
        left: 20px;
        right: 20px;
        background: #1a1a2e;
        color: white;
        padding: 14px 20px;
        border-radius: 30px;
        text-align: center;
        font-size: 14px;
        z-index: 1100;
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(100px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .toast-notification.success {
        background: #28a745;
    }

    .toast-notification.error {
        background: #dc3545;
    }

    /* Triple Input Section */
    .triple-weight-input {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        background: white;
        padding: 12px;
        border-radius: 20px;
    }

    .weight-box {
        flex: 1;
        text-align: center;
        background: #f8f9fa;
        border-radius: 14px;
        padding: 8px 4px;
    }

        .weight-box label {
            font-size: 11px;
            color: #666;
            display: block;
            margin-bottom: 6px;
        }

        .weight-box input {
            width: 100%;
            text-align: center;
            border: 1px solid #e0e0e0;
            border-radius: 12px;
            padding: 8px 0;
            font-size: 14px;
            font-weight: 600;
            background: white;
        }

            .weight-box input:focus {
                outline: none;
                border-color: #b8860b;
            }

    /* Editable Rate */
    .editable-rate {
        display: flex;
        align-items: center;
        gap: 12px;
        background: #f8f9fa;
        border-radius: 16px;
        padding: 8px 16px;
    }

        .editable-rate span {
            color: #b8860b;
            font-weight: 600;
            font-size: 18px;
        }

        .editable-rate input {
            flex: 1;
            padding: 10px;
            border: 1px solid #e0e0e0;
            border-radius: 14px;
            font-size: 18px;
            font-weight: 700;
            text-align: right;
            background: white;
            color: #1a1a2e;
        }

        .editable-rate .rate-unit {
            color: #666;
            font-size: 14px;
            min-width: 45px;
        }
</style>

<div class="mobile-container">
    <!-- Header -->
    <div class="app-header">
        <div class="header-title">
            <h1>ক্রয়</h1>
            <p>সোনা ক্রয় করুন</p>
        </div>
        <div class="header-icon">
            <i class="fas fa-shopping-cart"></i>
        </div>
    </div>

    <!-- Gold Rate -->
    <div class="gold-rate-card">
        <div class="rate-title">
            <i class="fas fa-chart-line"></i>
            আজকের সোনার দর (প্রতি ভরি)
        </div>
        <div class="rate-grid" id="rateGrid">
            <!-- Rates will be loaded here -->
        </div>
    </div>

    <!-- Customer Selection -->
    <div class="form-card">
        <div class="section-title">
            <i class="fas fa-user"></i>
            গ্রাহক নির্বাচন
        </div>
        <select class="custom-select" id="customerSelect">
            <option value="">-- গ্রাহক নির্বাচন করুন --</option>
        </select>
    </div>

    <!-- Item Form -->
    <div class="form-card">
        <div class="section-title">
            <i class="fas fa-gem"></i>
            আইটেম তথ্য
        </div>

        <!-- Item Name -->
        <div class="input-group">
            <label class="input-label">আইটেমের নাম</label>
            <input type="text" class="input-field" id="itemName" placeholder="যেমন: সোনার চেইন, আংটি">
        </div>

        <!-- Karat Selection -->
        <div class="input-group">
            <label class="input-label">কারেট</label>
            <select class="custom-select" id="karatSelect">
                <option value="24K">24K</option>
                <option value="22K" selected>22K</option>
                <option value="21K">21K</option>
                <option value="20K">20K</option>
                <option value="19K">19K</option>
                <option value="18K">18K</option>
                <option value="17K">17K</option>
                <option value="16K">16K</option>
                <option value="15K">15K</option>
                <option value="14K">14K</option>
            </select>
        </div>

        <!-- Enhanced Weight Calculator: ভরি, আনা, রতি input together -->
        <div class="weight-calculator">
            <div class="calc-title">ওজন নির্ধারণ করুন (ভরি, আনা, রতি)</div>
            <div class="triple-weight-input">
                <div class="weight-box">
                    <label>ভরি</label>
                    <input type="number" step="any" id="voriInput" value="0" oninput="syncWeightFromVori()">
                </div>
                <div class="weight-box">
                    <label>আনা</label>
                    <input type="number" step="any" id="anaInput" value="0" oninput="syncWeightFromAna()">
                </div>
                <div class="weight-box">
                    <label>রতি</label>
                    <input type="number" step="any" id="ratiInput" value="0" oninput="syncWeightFromRati()">
                </div>
            </div>
            <div class="total-weight" id="gramDisplay">= 0.000 গ্রাম</div>
        </div>

        <!-- Rate per Vori (Editable) -->
        <div class="input-group">
            <label class="input-label">দর (প্রতি ভরি)</label>
            <div class="editable-rate">
                <span>৳</span>
                <input type="number" id="voriRateInput" step="1" value="5850" oninput="updateRateFromInput()">
                <span class="rate-unit">/ভরি</span>
            </div>
            <input type="hidden" id="ratePerVori">
        </div>

        <!-- Rate per Ana and Rati -->
        <div style="display: flex; gap: 12px; margin-bottom: 16px;">
            <div style="flex: 1; background: #f8f9fa; border-radius: 14px; padding: 10px; text-align: center;">
                <div style="font-size: 11px; color: #666;">প্রতি আনা</div>
                <div style="font-size: 14px; font-weight: 600; color: #b8860b;" id="anaRateDisplay">0</div>
            </div>
            <div style="flex: 1; background: #f8f9fa; border-radius: 14px; padding: 10px; text-align: center;">
                <div style="font-size: 11px; color: #666;">প্রতি রতি</div>
                <div style="font-size: 14px; font-weight: 600; color: #b8860b;" id="ratiRateDisplay">0</div>
            </div>
        </div>

        <!-- Total Price -->
        <div class="input-group">
            <label class="input-label">এই আইটেমের মূল্য</label>
            <div class="calc-input-group" style="background: linear-gradient(135deg, #fff4e0, #fff9f0); border-radius: 16px; padding: 14px 16px;">
                <span style="color: #b8860b; font-weight: 600;">৳</span>
                <span id="itemTotalDisplay" style="font-size: 22px; font-weight: 800; color: #b8860b;">0</span>
            </div>
            <input type="hidden" id="itemTotal">
            <input type="hidden" id="totalVoriHidden" value="0">
        </div>

        <button class="add-btn" onclick="addItem()">
            <i class="fas fa-plus-circle"></i>
            আইটেম যোগ করুন
        </button>
    </div>

    <!-- Items List -->
    <div class="items-list">
        <div class="section-title">
            <i class="fas fa-list"></i>
            যোগকৃত আইটেম
        </div>
        <div id="itemsContainer">
            <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <p>কোনো আইটেম যোগ করা হয়নি</p>
            </div>
        </div>
    </div>

    <!-- Footer Summary -->
    <div class="footer-summary">
        <div class="summary-row">
            <span class="summary-label">মোট আইটেম</span>
            <span class="summary-value" id="totalItems">0</span>
        </div>
        <div class="summary-row">
            <span class="summary-label">মোট ওজন</span>
            <span class="summary-value" id="totalWeight">0.000 গ্রাম</span>
        </div>
        <div class="summary-row grand-total">
            <span class="summary-label">মোট মূল্য</span>
            <span class="summary-value" id="grandTotal">৳ 0</span>
        </div>
        <div class="action-buttons">
            <button class="btn-clear" onclick="clearAll()">
                <i class="fas fa-trash-alt"></i> ক্লিয়ার
            </button>
            <button class="btn-save" onclick="savePurchase()">
                <i class="fas fa-save"></i> ক্রয় সম্পন্ন
            </button>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal-custom" id="successModal">
    <div class="modal-content-custom">
        <div class="modal-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="modal-title-custom">ক্রয় সম্পন্ন!</div>
        <div class="modal-text">ক্রয় সফলভাবে সম্পন্ন হয়েছে</div>
        <div class="modal-details" id="modalDetails"></div>
        <button class="modal-btn" onclick="closeModal()">ঠিক আছে</button>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/js/all.min.js"></script>
<script>
    // Conversion: 1 Vori = 16 Ana, 1 Ana = 6 Rati
    // 1 Vori = 11.664 Gram
    const VORI_TO_GRAM = 11.664;
    const VORI_TO_ANA = 16;
    const ANA_TO_RATI = 6;

    // Global variables
    let goldRates = [];
    let buyItems = [];
    let selectedKarat = '22K';
    let currentRatePerVori = 5850; // default 22K rate per vori

    // Mock customers data (directly in JavaScript)
    const mockCustomers = [
        { id: 1, name: "রহিম মিয়া", phone: "01712-345678" },
        { id: 2, name: "করিমা বেগম", phone: "01812-345679" },
        { id: 3, name: "শফিকুল ইসলাম", phone: "01912-345680" },
        { id: 4, name: "নাসরিন আক্তার", phone: "01612-345681" },
        { id: 5, name: "জাহিদ হাসান", phone: "01512-345682" },
        { id: 6, name: "ফাতেমা বেগম", phone: "01312-345683" },
        { id: 7, name: "আব্দুল্লাহ আল মামুন", phone: "01711-123456" },
        { id: 8, name: "শাহীন আক্তার", phone: "01822-234567" }
    ];

    // Mock gold rates
    const mockGoldRates = [
        { karat: "24K", buyingRate: 6100, sellingRate: 6200, change: 25 },
        { karat: "22K", buyingRate: 5850, sellingRate: 5950, change: 20 },
        { karat: "21K", buyingRate: 5600, sellingRate: 5700, change: 15 },
        { karat: "20K", buyingRate: 5350, sellingRate: 5450, change: 12 },
        { karat: "19K", buyingRate: 5100, sellingRate: 5200, change: 10 },
        { karat: "18K", buyingRate: 4900, sellingRate: 5000, change: 10 },
        { karat: "17K", buyingRate: 4700, sellingRate: 4800, change: 8 },
        { karat: "16K", buyingRate: 4500, sellingRate: 4600, change: 8 },
        { karat: "15K", buyingRate: 4300, sellingRate: 4400, change: 5 },
        { karat: "14K", buyingRate: 4100, sellingRate: 4200, change: 5 }
    ];

    $(document).ready(function() {
        loadGoldRates();
        loadCustomers();
    });

    // Load gold rates (using mock data)
    function loadGoldRates() {
        goldRates = mockGoldRates;
        renderRateGrid();
        // Set default rate
        updateRateByKarat('22K');
    }

    // Load customers (using mock data)
    function loadCustomers() {
        let options = '<option value="">-- গ্রাহক নির্বাচন করুন --</option>';
        for(let i = 0; i < mockCustomers.length; i++) {
            options += '<option value="' + mockCustomers[i].id + '">' + mockCustomers[i].name + ' (' + mockCustomers[i].phone + ')</option>';
        }
        $('#customerSelect').html(options);
    }

    // Render rate grid
    function renderRateGrid() {
        let html = '';
        for(let i = 0; i < goldRates.length; i++) {
            const rate = goldRates[i];
            const isActive = rate.karat === selectedKarat;
            html += '<div class="rate-item ' + (isActive ? 'active' : '') + '" onclick="selectKarat(\'' + rate.karat + '\', ' + rate.buyingRate + ')">' +
                        '<div class="rate-karat">' + rate.karat + '</div>' +
                        '<div class="rate-value">' + rate.buyingRate + '</div>' +
                    '</div>';
        }
        $('#rateGrid').html(html);
    }

    // Select karat and update rates
    function selectKarat(karat, ratePerGram) {
        selectedKarat = karat;
        // Convert per gram rate to per vori rate
        currentRatePerVori = ratePerGram * VORI_TO_GRAM;
        updateRateByKarat(karat);
        renderRateGrid();
        calculateTotalPriceFromWeight();
    }

    // Update rate displays based on selected karat
    function updateRateByKarat(karat) {
        // Find the rate per gram for selected karat
        let ratePerGram = 0;
        for(let i = 0; i < goldRates.length; i++) {
            if(goldRates[i].karat === karat) {
                ratePerGram = goldRates[i].buyingRate;
                break;
            }
        }

        currentRatePerVori = ratePerGram * VORI_TO_GRAM;

        // Update editable rate input
        $('#voriRateInput').val(Math.round(currentRatePerVori));

        // Calculate per ana and per rati
        updateRateDisplays();

        // Update karat select
        $('#karatSelect').val(karat);

        // Recalculate price if weight exists
        calculateTotalPriceFromWeight();
    }

    // Update rate displays from currentRatePerVori
    function updateRateDisplays() {
        const perAna = currentRatePerVori / VORI_TO_ANA;
        const perRati = perAna / ANA_TO_RATI;

        $('#anaRateDisplay').text('৳ ' + perAna.toFixed(2));
        $('#ratiRateDisplay').text('৳ ' + perRati.toFixed(2));
        $('#ratePerVori').val(currentRatePerVori);
        $('#voriRateDisplay').text(Math.round(currentRatePerVori).toLocaleString());
    }

    // Update rate from editable input
    function updateRateFromInput() {
        let newRate = parseFloat($('#voriRateInput').val()) || 0;
        if (newRate > 0) {
            currentRatePerVori = newRate;
            updateRateDisplays();
            calculateTotalPriceFromWeight();

            // Find and highlight matching karat based on rate per gram
            const ratePerGram = currentRatePerVori / VORI_TO_GRAM;
            let closestKarat = null;
            let minDiff = Infinity;
            for(let i = 0; i < goldRates.length; i++) {
                let diff = Math.abs(goldRates[i].buyingRate - ratePerGram);
                if(diff < minDiff) {
                    minDiff = diff;
                    closestKarat = goldRates[i].karat;
                }
            }
            if(closestKarat && minDiff < 50) {
                selectedKarat = closestKarat;
                $('#karatSelect').val(selectedKarat);
                renderRateGrid();
            }
        }
    }

    // ========== WEIGHT CALCULATION LOGIC (ভরি, আনা, রতি) ==========
    // Get total vori from the three inputs
    function getTotalVoriFromInputs() {
        let vori = parseFloat($('#voriInput').val()) || 0;
        let ana = parseFloat($('#anaInput').val()) || 0;
        let rati = parseFloat($('#ratiInput').val()) || 0;

        // Convert ana to vori (16 ana = 1 vori)
        let voriFromAna = ana / VORI_TO_ANA;
        // Convert rati to vori (1 ana = 6 rati, so 96 rati = 1 vori)
        let voriFromRati = rati / (VORI_TO_ANA * ANA_TO_RATI);

        let totalVori = vori + voriFromAna + voriFromRati;
        return totalVori;
    }

    // Update all weight inputs based on total vori
    function updateWeightInputsFromVori(totalVori) {
        if (isNaN(totalVori)) totalVori = 0;
        let voriPart = Math.floor(totalVori);
        let fractionalVori = totalVori - voriPart;
        let totalAna = fractionalVori * VORI_TO_ANA;
        let anaPart = Math.floor(totalAna);
        let fractionalAna = totalAna - anaPart;
        let ratiPart = Math.round(fractionalAna * ANA_TO_RATI);

        // Handle rounding where rati becomes 6
        if (ratiPart >= ANA_TO_RATI) {
            ratiPart = 0;
            anaPart += 1;
            if (anaPart >= VORI_TO_ANA) {
                anaPart = 0;
                voriPart += 1;
            }
        }

        $('#voriInput').val(voriPart);
        $('#anaInput').val(anaPart);
        $('#ratiInput').val(ratiPart);
    }

    // Called when vori input changes
    function syncWeightFromVori() {
        let vori = parseFloat($('#voriInput').val()) || 0;
        let ana = parseFloat($('#anaInput').val()) || 0;
        let rati = parseFloat($('#ratiInput').val()) || 0;

        // Total vori = vori from vori field + ana converted + rati converted
        let totalVori = vori + (ana / VORI_TO_ANA) + (rati / (VORI_TO_ANA * ANA_TO_RATI));
        updateWeightInputsFromVori(totalVori);
        calculateTotalPriceFromWeight();
    }

    // Called when ana input changes
    function syncWeightFromAna() {
        let vori = parseFloat($('#voriInput').val()) || 0;
        let ana = parseFloat($('#anaInput').val()) || 0;
        let rati = parseFloat($('#ratiInput').val()) || 0;

        let totalVori = vori + (ana / VORI_TO_ANA) + (rati / (VORI_TO_ANA * ANA_TO_RATI));
        updateWeightInputsFromVori(totalVori);
        calculateTotalPriceFromWeight();
    }

    // Called when rati input changes
    function syncWeightFromRati() {
        let vori = parseFloat($('#voriInput').val()) || 0;
        let ana = parseFloat($('#anaInput').val()) || 0;
        let rati = parseFloat($('#ratiInput').val()) || 0;

        let totalVori = vori + (ana / VORI_TO_ANA) + (rati / (VORI_TO_ANA * ANA_TO_RATI));
        updateWeightInputsFromVori(totalVori);
        calculateTotalPriceFromWeight();
    }

    // Calculate total price based on current weight and rate
    function calculateTotalPriceFromWeight() {
        let totalVori = getTotalVoriFromInputs();
        let gram = totalVori * VORI_TO_GRAM;
        let totalPrice = totalVori * currentRatePerVori;

        $('#gramDisplay').text('= ' + gram.toFixed(3) + ' গ্রাম (' + totalVori.toFixed(4) + ' ভরি)');
        $('#itemTotalDisplay').text(totalPrice.toLocaleString());
        $('#itemTotal').val(totalPrice);
        $('#totalVoriHidden').val(totalVori);

        return { gram: gram, vori: totalVori, total: totalPrice };
    }

    // Add item to list
    function addItem() {
        const customerId = $('#customerSelect').val();
        const customerText = $('#customerSelect option:selected').text();
        const customerName = customerText.split('(')[0].trim();
        const itemName = $('#itemName').val().trim();
        const karat = $('#karatSelect').val();
        const totalPrice = parseFloat($('#itemTotal').val()) || 0;
        const totalVori = parseFloat($('#totalVoriHidden').val()) || 0;

        const voriInputVal = parseFloat($('#voriInput').val()) || 0;
        const anaInputVal = parseFloat($('#anaInput').val()) || 0;
        const ratiInputVal = parseFloat($('#ratiInput').val()) || 0;

        const gramAmount = totalVori * VORI_TO_GRAM;

        // Validation
        if (!customerId) {
            showToast('error', 'গ্রাহক নির্বাচন করুন');
            return;
        }
        if (!itemName) {
            showToast('error', 'আইটেমের নাম লিখুন');
            return;
        }
        if (totalVori <= 0) {
            showToast('error', 'সঠিক ওজন দিন (ভরি, আনা, রতি)');
            return;
        }
        if (totalPrice <= 0) {
            showToast('error', 'মূল্য গণনা করতে পারেনি');
            return;
        }

        const item = {
            id: Date.now(),
            customerId: customerId,
            customerName: customerName,
            itemName: itemName,
            karat: karat,
            voriPart: voriInputVal,
            anaPart: anaInputVal,
            ratiPart: ratiInputVal,
            voriAmount: totalVori,
            gramAmount: gramAmount,
            ratePerVori: currentRatePerVori,
            total: totalPrice
        };

        buyItems.push(item);
        renderItems();
        clearForm();
        showToast('success', 'আইটেম যোগ করা হয়েছে');
    }

    // Render items list
    function renderItems() {
        if (buyItems.length === 0) {
            $('#itemsContainer').html('<div class="empty-state">' +
                '<i class="fas fa-box-open"></i>' +
                '<p>কোনো আইটেম যোগ করা হয়নি</p>' +
                '</div>');
            updateSummary();
            return;
        }

        let html = '';
        for(let i = 0; i < buyItems.length; i++) {
            const item = buyItems[i];
            const weightDisplay = item.voriPart + ' ভরি ' + item.anaPart + ' আনা ' + item.ratiPart + ' রতি';

            html += '<div class="item-card">' +
                        '<div class="item-info">' +
                            '<div class="item-name">' + item.itemName + '</div>' +
                            '<div class="item-details">' + item.karat + ' | ' + weightDisplay + '</div>' +
                        '</div>' +
                        '<div class="item-price">' +
                            '<div class="item-amount">৳ ' + item.total.toLocaleString() + '</div>' +
                            '<div class="item-weight">' + item.gramAmount.toFixed(2) + ' গ্রাম</div>' +
                        '</div>' +
                        '<div class="delete-item" onclick="deleteItem(' + item.id + ')">' +
                            '<i class="fas fa-trash-alt"></i>' +
                        '</div>' +
                    '</div>';
        }
        $('#itemsContainer').html(html);
        updateSummary();
    }

    // Delete item
    function deleteItem(id) {
        if (confirm('আইটেমটি ডিলিট করতে চান?')) {
            const newItems = [];
            for(let i = 0; i < buyItems.length; i++) {
                if(buyItems[i].id !== id) {
                    newItems.push(buyItems[i]);
                }
            }
            buyItems = newItems;
            renderItems();
            showToast('success', 'আইটেম ডিলিট করা হয়েছে');
        }
    }

    // Clear form
    function clearForm() {
        $('#itemName').val('');
        $('#voriInput').val('0');
        $('#anaInput').val('0');
        $('#ratiInput').val('0');
        $('#itemTotalDisplay').text('0');
        $('#itemTotal').val('0');
        $('#gramDisplay').text('= 0.000 গ্রাম (0 ভরি)');
        $('#totalVoriHidden').val('0');
        calculateTotalPriceFromWeight();
    }

    // Clear all items
    function clearAll() {
        if (buyItems.length === 0) return;
        if (confirm('সব আইটেম ডিলিট করতে চান?')) {
            buyItems = [];
            renderItems();
            showToast('success', 'সব আইটেম ডিলিট করা হয়েছে');
        }
    }

    // Update summary
    function updateSummary() {
        let totalItems = buyItems.length;
        let totalVori = 0;
        let totalGram = 0;
        let grandTotal = 0;

        for(let i = 0; i < buyItems.length; i++) {
            totalVori += buyItems[i].voriAmount;
            totalGram += buyItems[i].gramAmount;
            grandTotal += buyItems[i].total;
        }

        $('#totalItems').text(totalItems);
        $('#totalWeight').text(totalGram.toFixed(3) + ' গ্রাম (' + totalVori.toFixed(3) + ' ভরি)');
        $('#grandTotal').text('৳ ' + grandTotal.toLocaleString());
    }

    // Save purchase
    function savePurchase() {
        if (buyItems.length === 0) {
            showToast('error', 'কোনো আইটেম যোগ করা হয়নি');
            return;
        }

        const customerId = $('#customerSelect').val();
        if (!customerId) {
            showToast('error', 'গ্রাহক নির্বাচন করুন');
            return;
        }

        let totalVori = 0;
        let totalGram = 0;
        let grandTotal = 0;
        for(let i = 0; i < buyItems.length; i++) {
            totalVori += buyItems[i].voriAmount;
            totalGram += buyItems[i].gramAmount;
            grandTotal += buyItems[i].total;
        }

        const customerText = $('#customerSelect option:selected').text();
        const customerName = customerText.split('(')[0].trim();

        // Show modal with details
        const modalDetails = '<div style="display: flex; justify-content: space-between; margin-bottom: 8px;">' +
                                '<span>গ্রাহক:</span>' +
                                '<span><strong>' + customerName + '</strong></span>' +
                            '</div>' +
                            '<div style="display: flex; justify-content: space-between; margin-bottom: 8px;">' +
                                '<span>মোট আইটেম:</span>' +
                                '<span><strong>' + buyItems.length + ' টি</strong></span>' +
                            '</div>' +
                            '<div style="display: flex; justify-content: space-between; margin-bottom: 8px;">' +
                                '<span>মোট ওজন:</span>' +
                                '<span><strong>' + totalGram.toFixed(3) + ' গ্রাম</strong><br><small>(' + totalVori.toFixed(3) + ' ভরি)</small></span>' +
                            '</div>' +
                            '<div style="display: flex; justify-content: space-between; margin-top: 8px; padding-top: 8px; border-top: 1px solid #e0e0e0;">' +
                                '<span style="font-weight: 600;">মোট মূল্য:</span>' +
                                '<span style="font-weight: 700; color: #b8860b;">৳ ' + grandTotal.toLocaleString() + '</span>' +
                            '</div>';

        $('#modalDetails').html(modalDetails);
        $('#successModal').fadeIn(200);
    }

    // Close modal
    function closeModal() {
        $('#successModal').fadeOut(200);
        // Reset after save
        buyItems = [];
        renderItems();
        clearForm();
        showToast('success', 'ক্রয় সম্পন্ন হয়েছে');
    }

    // Show toast notification
    function showToast(type, message) {
        const toast = document.createElement('div');
        toast.className = 'toast-notification ' + type;
        toast.innerHTML = '<i class="fas ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle') + '"></i> ' + message;
        document.body.appendChild(toast);

        setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() {
                if(toast.parentNode) toast.parentNode.removeChild(toast);
            }, 300);
        }, 2000);
    }

    // Karat change handler
    $('#karatSelect').on('change', function() {
        const karat = $(this).val();
        // Find rate for this karat
        let ratePerGram = 0;
        for(let i = 0; i < goldRates.length; i++) {
            if(goldRates[i].karat === karat) {
                ratePerGram = goldRates[i].buyingRate;
                break;
            }
        }
        if(ratePerGram > 0) {
            currentRatePerVori = ratePerGram * VORI_TO_GRAM;
            $('#voriRateInput').val(Math.round(currentRatePerVori));
            updateRateDisplays();
            selectedKarat = karat;
            renderRateGrid();
            calculateTotalPriceFromWeight();
        }
    });

    // Initial calculation on page load
    setTimeout(() => {
        calculateTotalPriceFromWeight();
    }, 100);
</script>